# Backtrader Web 环境配置示例
# 复制此文件为 .env 并修改配置

# ============== 应用配置 ==============
APP_NAME=backtrader_web
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# ============== 数据库配置 ==============
# 支持: sqlite, postgresql, mysql, mongodb
DATABASE_TYPE=sqlite
DATABASE_URL=sqlite+aiosqlite:///./backtrader.db

# PostgreSQL示例:
# DATABASE_TYPE=postgresql
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/backtrader

# MySQL示例:
# DATABASE_TYPE=mysql
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/backtrader

# ============== 数据库初始化 ==============
# 重要: 数据库初始化和默认管理员创建不再在应用启动时自动执行
# 首次部署或开发环境需要手动运行初始化脚本

# 初始化命令（开发环境）:
#   python scripts/init_db.py --init-all

# 或分别执行:
#   python scripts/init_db.py --create-tables
#   python scripts/init_db.py --create-admin

# 生产环境建议:
# 1. 使用数据库迁移工具（如 Alembic）管理表结构变更
# 2. 通过专门的初始化命令或配置管理工具创建管理员账户
# 3. 避免在应用启动时隐式执行数据库结构变更

# ============== 可选: Redis缓存 ==============
# 不配置则使用内存缓存
# REDIS_URL=redis://localhost:6379/0

# ============== JWT配置 ==============
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ============== 服务配置 ==============
HOST=0.0.0.0
PORT=8000

# 回测子进程超时（秒）
BACKTEST_TIMEOUT=300

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=http://localhost:3000

# SQL 日志（调试用）
SQL_ECHO=false

# ============== 管理员账户 ==============
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
