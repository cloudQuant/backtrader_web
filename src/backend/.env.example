# Backtrader Web Docker environment example
# Replace all placeholder secrets before use.

# App
APP_NAME=backtrader_web
DEBUG=false
SECRET_KEY=replace-with-a-random-secret-key-at-least-32-chars
JWT_SECRET_KEY=replace-with-a-random-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=backtrader
DB_PASSWORD=replace-with-your-mysql-password
DB_NAME=backtrader_web
MYSQL_ROOT_PASSWORD=replace-with-your-mysql-root-password
MYSQL_DATA_DIR=./runtime/mysql

# Redis
REDIS_DATA_DIR=./runtime/redis

# Backend runtime
BACKEND_LOGS_DIR=./runtime/backend/logs
BACKEND_APP_DATA_DIR=./runtime/backend/data
DB_AUTO_CREATE_SCHEMA=false
DB_AUTO_CREATE_DEFAULT_ADMIN=false
BACKTEST_TIMEOUT=300
AKSHARE_SCHEDULER_TIMEZONE=Asia/Shanghai
AKSHARE_SCRIPT_ROOT=app/data_fetch/scripts
AKSHARE_INTERFACE_BOOTSTRAP_MODE=manual
TZ=Asia/Shanghai

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_EMAIL=admin@example.com

# Network
HTTP_PORT=80
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Local Docker override values
LOCAL_HTTP_PORT=8080
LOCAL_BACKEND_PORT=8000
LOCAL_REDIS_DATA_DIR=./runtime/local/redis
LOCAL_BACKEND_LOGS_DIR=./runtime/local/backend/logs
LOCAL_BACKEND_APP_DATA_DIR=./runtime/local/backend/data
