# EditorConfig - https://editorconfig.org
# 统一编辑器配置，确保跨 IDE 一致的代码风格

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{py}]
indent_style = space
indent_size = 4

[*.{js,ts,vue,json,yml,yaml,md}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
